{
  "name": "usersservice",
  "version": "1.0.0",
  "description": "Global user accounts, authentication, and profile management",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --experimental-test-module-mocks \"src/**/!(*.integration).test.ts\"",
    "test:integration": "tsx --env-file=.env.test src/db/migrate.ts && tsx --env-file=.env.test --test --test-concurrency=1 \"src/**/*.integration.test.ts\"",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.19.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^7.0.11"
  },
  "license": "ISC"
}