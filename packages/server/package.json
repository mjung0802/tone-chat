{
  "name": "tone-chat-server",
  "version": "0.0.0",
  "description": "BFF server — routes client requests to backend services",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --experimental-test-module-mocks \"src/**/!(*.integration).test.ts\"",
    "test:integration": "tsx --env-file=.env.test --test --test-concurrency=1 \"src/**/*.integration.test.ts\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.9"
  },
  "license": "MIT"
}
