{
  "name": "messagingservice",
  "version": "1.0.0",
  "description": "Backend service for servers, channels, messages, members, and invites",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --experimental-test-module-mocks \"src/**/!(*.integration).test.ts\"",
    "test:integration": "tsx --env-file=.env.test --test --test-concurrency=1 \"src/**/*.integration.test.ts\""
  },
  "dependencies": {
    "express": "^5.2.1",
    "mongoose": "^8.14.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.1.1"
  },
  "license": "ISC"
}
