{
  "name": "attachmentsservice",
  "version": "1.0.0",
  "description": "File storage and attachment management service",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --experimental-test-module-mocks \"src/**/!(*.integration).test.ts\"",
    "test:integration": "tsx --env-file=.env.test src/db/migrate.ts && tsx --env-file=.env.test --test \"src/**/*.integration.test.ts\"",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "postgres": "^3.4.7",
    "tone-chat-logger": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12"
  },
  "license": "ISC"
}
