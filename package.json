{
  "name": "root",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "1.0.0",
  "description": "A tone-based chat app",
  "main": "index.js",
  "scripts": {
    "test": "pnpm --filter \"*\" test",
    "test:integration": "pnpm --filter usersservice --filter messagingservice --filter attachmentsservice --if-present run test:integration",
    "test:integration:up": "docker compose -f docker-compose.test.yml up -d --wait && pnpm test:integration && docker compose -f docker-compose.test.yml down -v",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjung0802/tone-chat.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mjung0802/tone-chat/issues"
  },
  "homepage": "https://github.com/mjung0802/tone-chat#readme",
  "pnpm": {
    "overrides": {
      "pretty-format": "^29.7.0"
    }
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "lerna": "^9.0.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}