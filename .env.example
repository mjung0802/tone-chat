# Auto-generated by setup.sh — run `bash setup.sh` to create .env
# To regenerate: remove .env and re-run setup.sh

# === Secrets (auto-generated) ===
JWT_SECRET=                    # 32-byte hex, shared between BFF and usersService
INTERNAL_API_KEY=              # 32-byte hex, authenticates inter-service calls
DB_PASSWORD=                   # 32-byte hex, PostgreSQL password for tone user
S3_ACCESS_KEY=                 # 32-byte hex, MinIO root access key
S3_SECRET_KEY=                 # 32-byte hex, MinIO root secret key

# === Deployment (set by setup.sh prompt) ===
DOMAIN=:80                     # Hostname for Caddy (e.g. chat.example.com); :80 = plain HTTP
ALLOWED_ORIGINS=http://localhost  # Comma-separated allowed CORS origins

# === SMTP (optional) ===
# Leave blank to print email verification OTPs to the usersService console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
